# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# TinaCMS (gerados no build)
/tina/__generated__
/public/admin

# Painel (self-hosted)
/painel/node_modules
/painel/.auth.json

# Peças de divulgação (marketing, geradas localmente)
/divulgacao

# PDFs da documentação (gerados a partir dos .md em docs/)
/docs/*.pdf
